# Copy to .env.local and fill in. .env.local is gitignored.

# Optional. Origin of the FastAPI audit backend the app proxies to via
# /api/backend/*. Defaults to http://localhost:8001 when unset.
# BACKEND_URL=http://localhost:8001

# Required. Signs the session cookies. Generate with: npx auth secret
AUTH_SECRET=

# Built-in demo email/password login (self-contained, no database).
DEMO_EMAIL=demo@critique.app
DEMO_PASSWORD=password123

# --- Optional OAuth. Fill these in to activate the social buttons. ---
# Google:  https://console.cloud.google.com/
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft (Entra ID):  https://portal.azure.com/
#   Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
