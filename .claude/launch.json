{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cvc-dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "cvc-dashboard-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "cvc-backend",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["backend.main:app", "--port", "8001"],
      "port": 8001
    }
  ]
}
